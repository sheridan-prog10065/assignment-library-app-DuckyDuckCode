<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryAdminPage"
             Title="Manage Book Assets">
    <Grid RowDefinitions="*,*,Auto" ColumnDefinitions="*,Auto,*">
        <Label Text="Register A Book Here"
               FontSize="Large"
               Grid.Column="1"
               HorizontalOptions="Center"
               VerticalOptions="Center"/>
        <VerticalStackLayout Grid.Row="1" Grid.Column="1">
            <Entry x:Name="_txtBookName" Placeholder="Book Name" Grid.Row="1"/>
            <Entry x:Name="_txtBookISBN" Placeholder="Book ISBN" Grid.Row="1"/>
            <Entry x:Name="_txtBookAuthorList" Placeholder="Book author list seperated with commas" Grid.Row="1"/>
            <Entry x:Name="_txtBookAssetList" Placeholder="Book asset list seperated with commas" Grid.Row="1"/>
        </VerticalStackLayout>

        <Button Text="Register Book" Grid.Row="2" Grid.Column="1" Margin="0,0,0,100" HeightRequest="100" Clicked="OnRegisterBook"/>
    </Grid>
</ContentPage>