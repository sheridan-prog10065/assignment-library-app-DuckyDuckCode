<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryBrowsePage"
             Title="Browse Interactive Library">
    <Grid>
        <Grid x:Name="_viewMainMenu" RowDefinitions="*,*,*" ColumnDefinitions="*,*,*">
            <Label Text="Main Menu"
           Grid.Column="1"
	       />
            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" >
                <Entry x:Name="_txtSearchBook"  Margin="0,100,0,0" Placeholder="Book Name or ISBN" Grid.Row="1"/>
                <Button Text="Select Book"  Margin="0,100,0,0" Clicked="OnViewBookMenu"/>
            </VerticalStackLayout>

        </Grid>




        <Grid x:Name="_viewBookMenu" RowDefinitions="*,*,*" ColumnDefinitions="*,*,*" IsVisible="False">
            <Label Text="What would you like to do with this book?"
             Grid.Column="1" VerticalOptions="Center" HorizontalOptions="Center"
              />
            <Entry x:Name="_txtBookReturn" Placeholder="Enter ID of book to return here" Grid.Row="1"/>
            <VerticalStackLayout Grid.Column="1"  Grid.Row="2">
                <Button Text="Check Status"  Clicked="OnCheckStatus"/>
                <Button Text="Borrow Book"  Clicked="OnBorrowBook"/>
                <Button Text="Return Book"  Clicked="OnReturnBook"/>
                <Button Text="Display Book Assets"  Clicked="OnDisplayBookAssets"/>
                <Button Text="Exit"  Clicked="OnReturnToMainMenu"/>
            </VerticalStackLayout>
        </Grid>



        <Grid x:Name="_viewLibraryAssets" RowDefinitions="*,*,*" ColumnDefinitions="*,*,*" IsVisible="False">
            <Label Text="Library Assets"
              VerticalOptions="Center"
             />
            <Button Text="Exit"  Grid.Column="2" Grid.Row="2" Clicked="OnReturnToBookMenu"/>
            <CollectionView x:Name="_lstBookAssets" Grid.Column="1"  VerticalOptions="End"
             HorizontalOptions="Fill"
              />

        </Grid>



    </Grid>

</ContentPage>
